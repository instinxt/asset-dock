generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  IMAGE
  VIDEO
  DOCUMENT
  MODEL_3D
  OTHER
}

model Asset {
  id           String    @id @default(cuid())

  fileName     String
  originalName String

  filePath     String
  fileSize     Int

  mimeType     String

  assetType    AssetType

  tags         String[]

  // 3D metadata
  vertices     Int?
  polygons     Int?
  dimensions   Json?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([fileName])
  @@index([assetType])
}